# Copy this file to `.env` and fill in your key to skip pasting it in the UI.
# Vite only exposes vars prefixed with VITE_ to the browser.
# NOTE: this bundles the key into the client at build time — fine for local
# dev, but don't ship a production build made with a real key in here.
VITE_SILICONFLOW_API_KEY=sk-your-key-here

# SiliconFlow has two separate platforms with separate accounts/keys.
# Default is the international host (api.siliconflow.com). If your key is from
# the China platform, uncomment the line below. (No VITE_ prefix — this is used
# by the dev-server proxy, not the browser.)
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn
