# Copy this file to `.env` and fill in your key and provider URL to skip pasting them in the UI.
# Vite only exposes vars prefixed with VITE_ to the browser.
# NOTE: this bundles the key into the client at build time — fine for local
# dev, but don't ship a production build made with a real key in here.
VITE_API_KEY=sk-your-key-here
VITE_PROVIDER_URL=https://api.siliconflow.com

# Example for OpenAI:
# VITE_API_KEY=sk-...your-openai-key...
# VITE_PROVIDER_URL=https://api.openai.com
